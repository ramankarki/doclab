{
  "name": "doclab",
  "version": "1.9.2",
  "description": "Local knowledge server for coding agents — fresh docs and articles on demand via HTTP",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "homepage": "https://github.com/ramankarki/doclab#readme",
  "bugs": {
    "url": "https://github.com/ramankarki/doclab/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "doclab": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target bun && bun build src/server-daemon.ts --outdir dist --target bun",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "prepare": "bun .husky/install.mjs",
    "publish:dry": "npm pack --dry-run",
    "dev": "bun run --watch src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "sqlite-vec": "^0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/bun": "latest",
    "@types/turndown": "^5.0.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramankarki/doclab.git"
  },
  "keywords": [
    "doclab",
    "documentation",
    "knowledge-server",
    "rag",
    "embeddings",
    "ollama",
    "sqlite-vec",
    "semantic-search",
    "coding-agent",
    "ai-agent",
    "llm-tools",
    "vector-search",
    "hybrid-search",
    "local-first",
    "privacy"
  ]
}
